{
  "name": "propcast",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Auto-spawned, trustlessly-settled goal-grain micro-prop markets on Solana, priced off TxLINE.",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit && npm --prefix ui run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "cleanroom": "bash scripts/check_cleanroom.sh",
    "cleanroom:selftest": "bash scripts/cleanroom_selftest.sh",
    "doc-drift": "bash scripts/check_doc_drift.sh",
    "xss-guard": "bash scripts/check_no_xss_sinks.sh",
    "ui:build": "npm --prefix ui run build"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^22.20.0",
    "solana-bankrun": "^0.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

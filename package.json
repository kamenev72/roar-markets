{
  "name": "propcast",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "description": "Goal-grain micro-market prototype with immutable TxLINE receipt binding on Solana.",
  "scripts": {
    "build": "tsc --noEmit -p config/typescript/tsconfig.json",
    "typecheck": "tsc --noEmit -p config/typescript/tsconfig.json && npm --prefix app run build",
    "test": "vitest run --config config/typescript/vitest.config.ts",
    "test:watch": "vitest --config config/typescript/vitest.config.ts",
    "cleanroom": "bash scripts/check_cleanroom.sh",
    "cleanroom:selftest": "bash scripts/cleanroom_selftest.sh",
    "doc-drift": "bash scripts/check_doc_drift.sh",
    "xss-guard": "bash scripts/check_no_xss_sinks.sh",
    "ui:build": "npm --prefix app run build",
    "ui:bundle-check": "node scripts/check_ui_bundle.mjs",
    "ui:e2e": "npm --prefix app run e2e",
    "judge-demo": "npm test && npm run typecheck && npm run ui:bundle-check && npm run ui:e2e && npm run cleanroom && npm run cleanroom:selftest && npm run doc-drift && npm run xss-guard"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^22.20.0",
    "solana-bankrun": "^0.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
